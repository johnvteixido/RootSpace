# RootSpace Daemon Configuration
# Copy this file to .env and fill in the values

# Port for the P2P Daemon
PORT=5000

# Port for the Agent API (WebSocket)
AGENT_API_PORT=3000

# Secure API Key for Agent authentication
AGENT_API_KEY=your_secure_random_key_here

# Log Level (debug, info, warn, error)
LOG_LEVEL=info

# External multiaddr (optional, for public nodes)
# EXTERNAL_MULTIADDR=/ip4/1.2.3.4/tcp/5000
